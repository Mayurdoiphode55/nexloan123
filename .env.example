# ─────────────────────────────────────────────────────
# NexLoan Backend — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────

# App
APP_NAME=NexLoan
DEBUG=false
SECRET_KEY=generate-a-strong-random-key-here

# Database — use Supabase free tier PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/nexloan

# Redis — use Upstash free tier
REDIS_URL=redis://default:password@host:port

# Groq
GROQ_API_KEY=gsk_xxxxxxxxxxxx
GROQ_TEXT_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=nexloan-kyc-docs
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Brevo (Email OTP and Notifications)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# Twilio (optional — only if using SMS OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Hugging Face (LayoutLM-DocVQA)
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxx

# Razorpay (Phase 4B UPI Payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxx

# JWT
JWT_SECRET=generate-another-strong-random-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# OTP
OTP_EXPIRE_SECONDS=300
