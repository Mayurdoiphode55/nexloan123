# NexLoan Root Gitignore

# Environment files
.env
.env.local
.env.*.local

# Allow example files and markdown prompts
!**.env.example

# Custom files to ignore
prompt.md
prompt1.md
prompt2.md
ui.md
UI.md
DEPLOYMENT.md
NexLoan_Project_Documentation.tex

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
backend/venv/
backend/env/

# Node / Next.js
node_modules/
.pnp
.pnp.js
frontend/.next/
frontend/out/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.vercel

# OS & Editor
.DS_Store
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
